Options -Indexes
ServerSignature Off
<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self'; font-src 'self'; script-src 'self' 'sha256-TrjibWVpZrZu1KtCAKYo+GqHhi4iO1ci99Q8MHG+WI4='; form-action 'self'; base-uri 'self'; frame-ancestors 'self'; upgrade-insecure-requests"
</IfModule>
<FilesMatch "^\.(env|git)|composer\.(json|lock)$">
Require all denied
</FilesMatch>
